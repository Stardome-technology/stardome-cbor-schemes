; ============================================================
; SEAD — Stardome Edge Accountability DAG
; Schema Version: 1.1.2
; ============================================================

; ---------- basic types ----------
hash32 = bstr .size 32
sig   = bstr
pk    = bstr
id    = bstr

protocol_version = tstr
org_id    = id
edge_id   = id
module_id = id

timestamp = uint
uint64 = uint

; ---------- optional DAG-linking fields ----------
; These fields are embedded into event bodies (and are hashed/signed).

dag_links = {
  ? 90: [* hash32],   ; parents (DAG edges)
  ? 91: hash32,       ; writer_prev (per-signer chaining)
  ? 92: uint64,       ; writer_seq
  ? 93: [* hash32]    ; observed_heads (frontier summary)
}

; ---------- SEAD event envelope ----------
; event_id = H(canonical_cbor(event_body))
; signature = Sign(canonical_cbor({event_type, event_id}))

sead_event = {
  1: protocol_version,
  2: uint,          ; event_type
  3: hash32,        ; event_id
  4: sead_body,     ; event body
  5: sig            ; signature of {event_type, event_id}
}

; event_type enumeration

event_type = &(
  org_genesis: 1,
  org_key_revoke: 2,
  edge_authorization: 10,
  edge_revocation: 11,
  edge_commit: 20,
  edge_batch_head: 21,
  edge_fault_proof: 30,
  edge_equivocation_proof: 31,
  storage_receipt: 40,
  frontier_summary: 50
)

; sead_body union

sead_body = org_genesis_body
          / org_key_revoke_body
          / edge_authorization_body
          / edge_revocation_body
          / edge_commit_body
          / edge_batch_head_body
          / edge_fault_proof_body
          / edge_equivocation_proof_body
          / storage_receipt_body
          / frontier_summary_body

; ---------- OrgGenesis ----------
; Envelope is signed by org writer key.
; Module endorsements inside are signed by modules.

org_genesis_body = {
  1: org_id,
  2: pk,              ; org_pk
  3: timestamp,       ; not_before
  4: timestamp,       ; not_after (0 if none)
  5: [+ module_endorsement],
  * dag_links
}

module_endorsement = {
  1: module_id,
  2: pk,              ; module_xmss_pk (or reference hash)
  3: sig              ; module signature over (org_id, org_pk, not_before, not_after)
}

org_key_revoke_body = {
  1: org_id,
  2: pk,              ; org_pk
  3: timestamp,       ; revoke_time
  4: tstr,            ; reason
  * dag_links
}

; ---------- Edge Authorization ----------
; Signed by org writer key in the envelope.

edge_authorization_body = {
  1: org_id,
  2: edge_id,
  3: pk,              ; edge_pk
  4: timestamp,       ; not_before
  5: timestamp,       ; not_after
  * dag_links
}

edge_revocation_body = {
  1: org_id,
  2: edge_id,
  3: timestamp,
  4: tstr,            ; reason
  * dag_links
}

; ---------- Receipt (host-facing) ----------
; Receipt is not necessarily written into SEAD; it is included in fault proofs.
; Edge signature target is implementation-defined but MUST bind payload_hash and deadline fields.

edge_ingest_receipt = {
  1: edge_id,
  2: org_id,
  3: module_id,
  4: hash32,          ; payload_hash
  5: timestamp,       ; received_time
  6: timestamp,       ; publish_deadline
  7: sig              ; edge signature
}
	
; ---------- Commit model ----------
; Signed by edge key in the envelope.
edge_commit_body = {
  1: edge_id,
  2: org_id,
  ; --- commit identification ---
  ? 3: hash32,         ; payload_hash (present for single commit)
  ; --- batch / sequencing ---
  ? 4: uint64,         ; batch_seq (present for batch commits)
  ; --- commitment ---
  5: hash32,           ; commitment_root
  ; --- optional linkage ---
  ? 6: [* hash32],     ; payload_list (optional explicit list)
  ; --- receipt binding ---
  ? 7: hash32,         ; receipt_id (single commit)
  8: timestamp,
  * dag_links
}

; ===============================
; SEMANTIC RULES (informal)
; ===============================

; Single commit:
; - field 3 (payload_hash) MUST be present
; - field 4 (batch_seq) MUST NOT be present
; - commitment_root == payload_hash

; Batch commit:
; - field 4 (batch_seq) MUST be present
; - commitment_root commits to a set of payload_hash values
;   (e.g. Merkle root or equivalent)

; payload_list is OPTIONAL (debug / transparency / small batches)

; ---------- Fault Proofs ----------
; Signed by an org writer key in the envelope.

edge_fault_proof_body = {
  1: edge_id,         ; accused_edge_id
  2: org_id,
  3: uint,            ; fault_type (1=missed_deadline)
  4: bstr,            ; receipt_cbor (embedded receipt bytes)
  5: timestamp,       ; observed_time
  6: tstr,            ; notes
  * dag_links
}

edge_equivocation_proof_body = {
  1: edge_id,
  2: org_id,
  3: uint,            ; eq_type 
  4: bstr,            ; obj_a_cbor
  5: bstr,            ; obj_b_cbor
  6: timestamp,
  7: tstr,            ; notes
  * dag_links
}

; ---------- Optional Storage Receipts ----------

storage_receipt_body = {
  1: org_id,
  2: edge_id,
  3: hash32,          ; payload_hash
  4: tstr,            ; storage_cid (IPFS CID or other identifier)
  5: timestamp,
  6: uint,            ; retention_policy
  7: sig,             ; storage actor signature (or edge signature if same)
  * dag_links
}

; ---------- Frontier Summary ----------
; Signed by org writer key.

frontier_summary_body = {
  1: org_id,
  2: timestamp,
  3: [* hash32],      ; observed_heads
  4: hash32,          ; summary_id = H(canonical_cbor(al))
  * dag_links
}
